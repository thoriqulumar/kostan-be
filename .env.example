ENV=DEVELOPMENT

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=kostan_admin
DB_PASSWORD=kostan_password_2024
DB_DATABASE=kostan_db

# JWT Configuration
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRES_IN=7d

# Application Configuration
PORT=3000
NODE_ENV=DEVELOPMENT

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3001

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_DESTINATION=./uploads

# Email Configuration (Gmail SMTP)
# To enable: Configure with valid SMTP credentials
# For Gmail: Create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:5173

# Payment Notification Configuration
# Note: Reminders are automatically sent daily via in-app notifications (SSE)
# Email notifications are DISABLED - only in-app notifications will be sent
# Each tenant receives reminders on the day matching their rentStartDate
# Example: Rent started on Nov 18 → reminders sent on 18th of each month